# RushMedz Mobile Apps - Environment Variables
# Copy this file to .env.local in each mobile app directory

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8086

# Admin App URL (for linking back to admin)
EXPO_PUBLIC_ADMIN_URL=http://localhost:5173

# WebSocket URL for real-time events
EXPO_PUBLIC_WS_URL=ws://localhost:8086/ws/events

# Supabase Configuration (optional - for direct database access)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Development mode flag
EXPO_PUBLIC_DEV_MODE=true

# App-specific configuration
# For DoctorApp:
# EXPO_PUBLIC_APP_TYPE=doctor

# For DriverApp:
# EXPO_PUBLIC_APP_TYPE=driver

# For MerchantApp:
# EXPO_PUBLIC_APP_TYPE=merchant

# For UserApp:
# EXPO_PUBLIC_APP_TYPE=user
